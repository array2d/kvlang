{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kvlang",
  "scopeName": "source.kv",
  "fileTypes": ["kv"],
  "patterns": [
    {
      "comment": "Line comment: # ...",
      "name": "comment.line.number-sign.kv",
      "match": "#.*$"
    },
    {
      "comment": "Double-quoted string",
      "name": "string.quoted.double.kv",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "name": "constant.character.escape.kv", "match": "\\\\." }]
    },
    {
      "comment": "Single-quoted key reference",
      "name": "string.quoted.single.kv",
      "begin": "'",
      "end": "'"
    },
    {
      "comment": "Path literals: ./foo, /data/bar",
      "name": "support.variable.path.kv",
      "match": "\\.?/[a-zA-Z0-9_./]+"
    },
    {
      "comment": "Arrows: -> and <-",
      "name": "keyword.operator.arrow.kv",
      "match": "->|<-"
    },
    {
      "comment": "Multi-char operators",
      "name": "keyword.operator.comparison.kv",
      "match": "==|!=|<=|>=|&&|\\|\\||<<|>>"
    },
    {
      "comment": "Single-char operators",
      "name": "keyword.operator.arithmetic.kv",
      "match": "[+\\-*/%<>!&|^]"
    },
    {
      "comment": "Numeric literal",
      "name": "constant.numeric.kv",
      "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+\\-]?[0-9]+)?\\b"
    },
    {
      "comment": "Boolean literals",
      "name": "constant.language.boolean.kv",
      "match": "\\b(true|false)\\b"
    },
    {
      "comment": "Control keywords",
      "name": "keyword.control.kv",
      "match": "\\b(if|for|return)\\b"
    },
    {
      "comment": "def keyword with function name",
      "begin": "\\b(def)\\b\\s+",
      "end": "\\{",
      "beginCaptures": {
        "1": { "name": "keyword.other.def.kv" }
      },
      "patterns": [
        { "name": "entity.name.function.kv", "match": "[a-zA-Z_][a-zA-Z0-9_.]*" },
        { "name": "keyword.operator.arrow.kv", "match": "->" },
        { "name": "variable.parameter.kv", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b" }
      ]
    },
    {
      "comment": "Function call or builtin name before '('",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)\\s*(?=\\()",
      "captures": { "1": { "name": "support.function.kv" } }
    },
    {
      "comment": "Type annotations (:int, :num, :float, :bool, :string)",
      "name": "storage.type.kv",
      "match": "(?<=:)\\s*[a-zA-Z_][a-zA-Z0-9_]*"
    },
    {
      "comment": "Braces",
      "name": "punctuation.definition.brace.kv",
      "match": "[{}]"
    },
    {
      "comment": "Parentheses",
      "name": "punctuation.definition.paren.kv",
      "match": "[()]"
    },
    {
      "comment": "Comma",
      "name": "punctuation.separator.comma.kv",
      "match": ","
    }
  ]
}
