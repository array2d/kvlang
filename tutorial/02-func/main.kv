# 期望输出:
#   add(10,20) = 30
#   double(add(10,20)) = 60
def add(A:int, B:int) -> (C:int) {
	A + B -> C
}

def double(x:int) -> (y:int) {
	y <- x * 2
}

def main() -> () {
	a = add(10, 20)  # = 等价于 <-
	print("add(10,20) =", a)
	double(a) -> b
	print("double(add(10,20)) =", b)
	a <- /last_a
	print("global last_a =", a)
}

main()
