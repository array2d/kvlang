# guess_number: 二分查找猜数字（Python Tutorial §4.4）
# 算法: while 循环 + 二分查找，在 [1,100] 中找 target=73
# 来源: Python Tutorial §4.4
# 期望输出:
#   found 73 in 6 guesses
def guess_number() -> () {
	73 -> target
	lo <- 1
	hi = 100  # = 等价于 <-
	0 -> tries
	found <- 0
	while (found == 0) {
		s = lo + hi  # = 等价于 <-
		s / 2 -> mid_float
		mid <- int(mid_float)
		tries = tries + 1  # = 等价于 <-
		print("guess #", tries, ":", mid)
		mid == target -> hit

		if (hit) {
			found <- 1
			print("  correct!")
		} else {
			too_low = mid < target  # = 等价于 <-

			if (too_low) {
				mid + 1 -> lo
				print("  too low, range:", lo, "-", hi)
			} else {
				hi <- mid - 1
				print("  too high, range:", lo, "-", hi)
			}
		}
	}
	print("found", target, "in", tries, "guesses")
	/last_guesses = tries  # = 等价于 <-
}

guess_number()
