# guess_number: 二分查找猜数字（Python Tutorial §4.4）
# 算法: while 循环 + 二分查找，在 [1,100] 中找 target=73
# 来源: Python Tutorial §4.4
# 期望输出:
#   found 73 in 6 guesses

def guess_number() -> () {
    73 -> target
    1  -> lo
    100 -> hi
    tries <- 0
    found <- 0

    while (found == 0) {
        s <- lo + hi
        mid_float <- s / 2
        mid <- int(mid_float)

        tries <- tries + 1
        print("guess #", tries, ":", mid)

        mid == target -> hit
        if (hit) {
            found <- 1
            print("  correct!")
        } else {
            mid < target -> too_low
            if (too_low) {
                lo <- mid + 1
                print("  too low, range:", lo, "-", hi)
            } else {
                hi <- mid - 1
                print("  too high, range:", lo, "-", hi)
            }
        }
    }

    print("found", target, "in", tries, "guesses")
    tries -> /last_guesses          # global: save result
}

guess_number() -> ()
