# 期望输出:
#   sum(1..10) = 55
#   first div7 in [1,20] = 7
#   sum odds(1..10) = 25
def sum_to(n:int64) -> (total:int64) {
	total <- 0
	i = 1  # = 等价于 <-
	while (i <= n) {
		total + i -> total
		i <- i + 1
	}
}

def first_div7(n:int64) -> (result:int64) {
	result = 0  # = 等价于 <-
	1 -> i
	while (i <= n) {
		rem <- i % 7
		hit = rem == 0  # = 等价于 <-

		if (hit) {
			i -> result
			i <- n + 1
		} else {
			i = i + 1  # = 等价于 <-
		}
	}
}

def sum_odds(n:int64) -> (total:int64) {
	0 -> total
	i <- 1
	while (i <= n) {
		rem = i % 2  # = 等价于 <-
		rem == 1 -> is_odd

		if (is_odd) {
			total <- total + i
		}

		i = i + 1  # = 等价于 <-
	}
}

sum_to(10) -> a
print("sum(1..10) =", a)
b <- first_div7(20)
print("first div7 in [1,20] =", b)
c = sum_odds(10)  # = 等价于 <-
print("sum odds(1..10) =", c)
a + b -> ab
/last_sum <- ab + c
