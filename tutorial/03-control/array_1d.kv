# array_1d: 一维数组 — 字面量创建、索引访问、遍历求和
# 语法: a <- [elem, ...]  对标 Python/NumPy
# 层级: P3
# 规则: P3-algo
# 期望输出:
#   len = 4
#   [0] = 10
#   sum = 100

def main() -> () {
    a <- [10, 20, 30, 40]          # 数组字面量
    len(a) -> n
    print("len =", n)

    at(a, 0) -> v0
    print("[0] =", v0)

    0 -> total
    0 -> i
    while (i < n) {
        at(a, i) -> x
        total + x -> total
        i + 1 -> i
    }
    print("sum =", total)
}

main() -> ()
