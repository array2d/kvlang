# 009 Palindrome Number
# 期望输出: true, false, false
def isPalindrome(x:int) -> (ok:bool) {
    false -> ok
    x < 0 -> neg
    x < 10 -> single
    0 -> skip
    if (neg) {
        true -> skip
    }
    if (skip == false) {
        if (single) {
            true -> ok
            true -> skip
        }
    }
    if (skip == false) {
        x -> orig
        0 -> rev
        while (orig > 0) {
            rev * 10 -> rev
            orig % 10 -> d
            rev + d -> rev
            orig / 10 -> t
            int(t) -> orig
        }
        rev == x -> ok
    }
}

isPalindrome(121) -> a
print("121", a)
isPalindrome(-121) -> b
print("-121", b)
isPalindrome(10) -> c
print("10", c)
a -> /pal_121
