# 169: Majority Element — Boyer-Moore 投票算法
# 算法: 计数抵消，多数元素必然存活
# 来源: LeetCode #169
# 期望输出:
#   3
def majority() -> () {
	a <- [3, 2, 3]
	len(a) -> n
	a[0] -> candidate
	1 -> count
	1 -> i
	while (i < n) {
		a[i] -> x
		count == 0 -> reset

		if (reset) {
			x -> candidate
			1 -> count
		} else {
			x == candidate -> match

			if (match) {
				count + 1 -> count
			} else {
				count - 1 -> count
			}
		}

		i + 1 -> i
	}
	print(candidate)
}

majority()
