# 344: Reverse String (用数组模拟) — 双指针反转
# 来源: LeetCode #344
# 期望输出:
#   o
#   l
#   l
#   e
#   h
def reverse_str() -> () {
	["h", "e", "l", "l", "o"] -> a
	n <- len(a)
	l = 0  # = 等价于 <-
	n - 1 -> r
	while (l < r) {
		tl <- a[l]
		tr = a[r]  # = 等价于 <-
		a[l] <- tr
		a[r] <- tl
		l + 1 -> l
		r <- r - 1
	}
	i = 0  # = 等价于 <-
	while (i < n) {
		a[i] -> x
		print(x)
		i <- i + 1
	}
}

reverse_str()
