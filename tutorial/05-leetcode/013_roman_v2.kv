# 013: Roman to Integer — 罗马数字转整数
# 来源: LeetCode #13
# 期望输出:
#   58
def roman_to_int(s:str) -> () {
	strlen(s) -> n
	result <- 0
	i = 0  # = 等价于 <-
	while (i < n) {
		char(s, i) -> c
		is_I <- c == "I"
		is_V = c == "V"  # = 等价于 <-
		c == "X" -> is_X
		is_L <- c == "L"
		is_C = c == "C"  # = 等价于 <-
		c == "D" -> is_D
		is_M <- c == "M"

		if (is_I) {
			ni = i + 1  # = 等价于 <-
			ni < n -> has_next

			if (has_next) {
				nc <- char(s, ni)
				iv = nc == "V"  # = 等价于 <-
				nc == "X" -> ix

				if (iv) {
					val <- 4
					i = i + 1  # = 等价于 <-
				} else {
					if (ix) {
						9 -> val
						i <- i + 1
					} else {
						val = 1  # = 等价于 <-
					}
				}
			} else {
				1 -> val
			}
		} else {
			if (is_V) {
				val <- 5
			} else {
				if (is_X) {
					val = 10  # = 等价于 <-
				} else {
					if (is_L) {
						50 -> val
					} else {
						if (is_C) {
							val <- 100
						} else {
							if (is_D) {
								val = 500  # = 等价于 <-
							} else {
								1000 -> val
							}
						}
					}
				}
			}
		}

		result <- result + val
		i = i + 1  # = 等价于 <-
	}
	print(result)
}

roman_to_int("LVIII")
