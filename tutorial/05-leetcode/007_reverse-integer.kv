# 007 Reverse Integer
# 期望输出: 321
def reverse(x:int) -> (r:int) {
    0 -> r
    if (x < 0) {
        -x -> n
    } else {
        x -> n
    }
    while (n > 0) {
        r * 10 -> r
        n % 10 -> d
        r + d -> r
        n / 10 -> n
    }
    if (x < 0) {
        -r -> r
    }
}

reverse(123) -> ans
print("ans =", ans)
ans -> /reverse_ans
