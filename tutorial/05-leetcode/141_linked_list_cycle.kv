# 141: Linked List Cycle — 快慢指针
# 来源: LeetCode #141
# 期望输出:
#   1
#   0
def has_cycle(head:str) -> (result:int) {
	result = 0  # = 等价于 <-
	head -> slow
	fast <- head
	while (fast != "") {
		slow = slow.next  # = 等价于 <-
		fast.next -> n1
		at_end <- n1 == ""

		if (at_end) {
			fast = ""  # = 等价于 <-
		} else {
			n1.next -> fast
			match <- slow == fast

			if (match) {
				result = 1  # = 等价于 <-
				"" -> fast
			}
		}
	}
}

def build_cycle() -> () {
	/c0.val <- 3
	/c0.next = "/c1"  # = 等价于 <-
	2 -> /c1.val
	/c1.next <- "/c2"
	/c2.val = 0  # = 等价于 <-
	"/c0" -> /c2.next
}

def build_no_cycle() -> () {
	/n0.val <- 1
	/n0.next = "/n1"  # = 等价于 <-
	2 -> /n1.val
	/n1.next <- ""
}

build_cycle()
r1 = has_cycle("/c0")  # = 等价于 <-
print(r1)
build_no_cycle()
has_cycle("/n0") -> r2
print(r2)
