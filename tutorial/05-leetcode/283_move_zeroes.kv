# 283: Move Zeroes — 移动零到末尾，保持非零顺序
# 算法: 读写双指针，写非零值
# 来源: LeetCode #283
# 期望输出:
#   1
#   3
#   12
#   0
#   0
def move_zeroes() -> () {
	a <- [0, 1, 0, 3, 12]
	n = len(a)  # = 等价于 <-
	0 -> w
	i <- 0
	while (i < n) {
		x = a[i]  # = 等价于 <-
		x == 0 -> skip

		if (skip) {
			i <- i + 1
		} else {
			a[w] <- x
			w = w + 1  # = 等价于 <-
			i + 1 -> i
		}
	}
	while (w < n) {
		a[w] <- 0
		w <- w + 1
	}
	j = 0  # = 等价于 <-
	while (j < n) {
		a[j] -> v
		print(v)
		j <- j + 1
	}
}

move_zeroes()
