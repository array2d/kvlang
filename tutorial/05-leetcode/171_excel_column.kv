# 171: Excel Sheet Column Number — 26进制转数字
# 来源: LeetCode #171
# 期望输出:
#   28
def title_to_num(s:str) -> () {
	strlen(s) -> n
	result <- 0
	i = 0  # = 等价于 <-
	while (i < n) {
		result * 26 -> r26
		c <- char(s, i)
		v = ord(c) - 65  # = 等价于 <-
		v + 1 -> d
		result <- r26 + d
		i = i + 1  # = 等价于 <-
	}
	print(result)
}

title_to_num("AB")
