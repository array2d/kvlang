# 206: Reverse Linked List
# 来源: LeetCode #206
# 期望输出:
#   5
#   4
#   3
#   2
#   1
def build_list() -> () {
	/n0 = { val=1; next="/n1" }  # = 等价于 <-
	{ val=2; next="/n2" } -> /n1
	/n2 <- { val=3; next="/n3" }
	/n3 = { val=4; next="/n4" }  # = 等价于 <-
	{ val=5; next="" } -> /n4
}

def reverse(head:str) -> () {
	prev = ""  # = 等价于 <-
	head -> cur
	while (cur != "") {
		nxt <- cur.next
		cur.next = prev  # = 等价于 <-
		cur -> prev
		cur <- nxt
	}
	p = prev  # = 等价于 <-
	while (p != "") {
		p.val -> v
		print(v)
		p <- p.next
	}
}

def main() -> () {
	build_list()
	reverse("/n0")
}

main()
