# 203: Remove Linked List Elements
# 来源: LeetCode #203
# 期望输出:
#   1
#   2
#   3
#   4
#   5
def build_list() -> () {
	/n0.val = 1  # = 等价于 <-
	"/n1" -> /n0.next
	/n1.val <- 2
	/n1.next = "/n2"  # = 等价于 <-
	6 -> /n2.val
	/n2.next <- "/n3"
	/n3.val = 3  # = 等价于 <-
	"/n4" -> /n3.next
	/n4.val <- 4
	/n4.next = "/n5"  # = 等价于 <-
	5 -> /n5.val
	/n5.next <- "/n6"
	/n6.val = 6  # = 等价于 <-
	"" -> /n6.next
}

def remove(head:str, val:int) -> () {
	p <- "/n0"
	while (p != "") {
		v = p.val  # = 等价于 <-
		v == val -> skip

		if (skip) {
		} else {
			print(v)
		}

		p <- p.next
	}
}

def main() -> () {
	build_list()
	remove("/n0", 6)
}

main()
