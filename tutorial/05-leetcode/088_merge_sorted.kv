# 088: Merge Sorted Array — 合并两个有序数组
# 算法: 双指针从后向前合并
# 来源: LeetCode #88
# 期望输出:
#   1
#   2
#   2
#   3
#   5
#   6
def merge() -> () {
	[1, 2, 3, 0, 0, 0] -> a
	m <- 3
	b = [2, 5, 6]  # = 等价于 <-
	3 -> n
	i <- m - 1
	j = n - 1  # = 等价于 <-
	m + n -> total
	k <- total - 1
	while (j >= 0) {
		i_ok = i >= 0  # = 等价于 <-

		if (i_ok) {
			a[i] -> av
			bv <- b[j]
			a_bigger = av > bv  # = 等价于 <-

			if (a_bigger) {
				a[k] <- av
				i - 1 -> i
			} else {
				a[k] <- bv
				j <- j - 1
			}
		} else {
			bv2 = b[j]  # = 等价于 <-
			a[k] <- bv2
			j - 1 -> j
		}

		k <- k - 1
	}
	x = 0  # = 等价于 <-
	while (x < 6) {
		a[x] -> v
		print(v)
		x <- x + 1
	}
}

merge()
