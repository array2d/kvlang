# 088: Merge Sorted Array — 合并两个有序数组
# 算法: 双指针从后向前合并
# 来源: LeetCode #88
# 期望输出:
#   1
#   2
#   2
#   3
#   5
#   6
def merge() -> () {
	a <- [1, 2, 3, 0, 0, 0]
	3 -> m
	b <- [2, 5, 6]
	3 -> n
	m - 1 -> i
	n - 1 -> j
	m + n -> total
	total - 1 -> k
	while (j >= 0) {
		i >= 0 -> i_ok

		if (i_ok) {
			a[i] -> av
			b[j] -> bv
			av > bv -> a_bigger

			if (a_bigger) {
				a[k] <- av
				i - 1 -> i
			} else {
				a[k] <- bv
				j - 1 -> j
			}
		} else {
			b[j] -> bv2
			a[k] <- bv2
			j - 1 -> j
		}

		k - 1 -> k
	}
	0 -> x
	while (x < 6) {
		a[x] -> v
		print(v)
		x + 1 -> x
	}
}

def main() -> () {
	merge()
}

main()
