# 001: Two Sum — O(n) hash map (h.*key 动态解引用)
# 来源: LeetCode #1
# 期望输出:
#   [ 0 , 1 ]

def two_sum(nums, target:int) -> () {
  len(nums) -> n; 0 -> i
  "/tmp" -> h
  while (i < n) {
    nums[i] -> x; target - x -> need
    h.*need -> j
    j -> found
    if (found) { j - 1 -> k; print("[", k, ",", i, "]"); n -> i }
    else { i + 1 -> v; set(h, x, v) -> _; i + 1 -> i }
  }
}

def main() -> () { two_sum([2,7,11,15], 9) -> () }
main() -> ()
