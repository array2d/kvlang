# 001: Two Sum — O(n) hash map (kvspace paths)
# 来源: LeetCode #1
# 期望输出:
#   [ 0 , 1 ]

def two_sum(nums, target:int) -> () {
  len(nums) -> n; 0 -> i
  while (i < n) {
    at(nums, i) -> x; target - x -> need
    at("/tmp", need) -> j
    j -> found
    if (found) { j - 1 -> k; print("[", k, ",", i, "]"); n -> i }
    else { i + 1 -> v; set("/tmp", x, v) -> _; i + 1 -> i }
  }
}

def main() -> () { two_sum([2,7,11,15], 9) -> () }
main() -> ()
