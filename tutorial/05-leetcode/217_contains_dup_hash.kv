# 217: Contains Duplicate — O(n) hash set
# 来源: LeetCode #217
# 期望输出:
#   true
#   false
def has_dup(a) -> () {
	len(a) -> n
	0 -> found
	0 -> i
	while (i < n) {
		a[i] -> x
		"/seen"[x] -> v
		v -> exists

		if (exists) {
			1 -> found
			n -> i
		} else {
			set("/seen", x, 1) -> _
			i + 1 -> i
		}
	}
	found -> f

	if (f) {
		print("true")
	} else {
		print("false")
	}
}

def no_dup() -> () {
	a <- [1, 2, 3, 4]
	len(a) -> n
	0 -> found
	0 -> i
	while (i < n) {
		a[i] -> x
		"/seen2"[x] -> v
		v -> exists

		if (exists) {
			1 -> found
			n -> i
		} else {
			set("/seen2", x, 1) -> _
			i + 1 -> i
		}
	}
	found -> f

	if (f) {
		print("true")
	} else {
		print("false")
	}
}
