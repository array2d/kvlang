# 053: Maximum Subarray — Kadane 算法
# 算法: 动态规划 O(n)，cur = max(x, cur+x)
# 来源: LeetCode #53
# 期望输出:
#   6

def max_subarray() -> () {
    a <- [-2, 1, -3, 4, -1, 2, 1, -5, 4]; len(a) -> n
    a[0] -> cur; a[0] -> max; 1 -> i
    
    while (i < n) {
        a[i] -> x
        cur + x -> curx
        x > curx -> take_x
        if (take_x) { x -> cur } else { curx -> cur }
        cur > max -> bigger
        if (bigger) { cur -> max }
        i + 1 -> i
    }
    print(max)
}
def main() -> () { max_subarray() -> () }
main() -> ()
