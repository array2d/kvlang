# 058: Length of Last Word
# 来源: LeetCode #58
# 期望输出:
#   5
def last_word_len(s:str) -> () {
	n = strlen(s)  # = 等价于 <-
	n - 1 -> i
	count <- 0
	while (i >= 0) {
		c = char(s, i)  # = 等价于 <-
		c == " " -> sp

		if (sp) {
			i <- -1
		} else {
			count = count + 1  # = 等价于 <-
		}

		i - 1 -> i
	}
	print(count)
}

last_word_len("Hello World")
