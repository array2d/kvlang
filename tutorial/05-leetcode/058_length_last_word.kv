# 058: Length of Last Word
# 来源: LeetCode #58
# 期望输出:
#   5
def last_word_len(s:str) -> () {
	strlen(s) -> n
	n - 1 -> i
	0 -> count
	while (i >= 0) {
		char(s, i) -> c
		c == 32 -> sp

		if (sp) {
			-1 -> i
		} else {
			count + 1 -> count
		}

		i - 1 -> i
	}
	print(count)
}

def main() -> () {
	last_word_len("Hello World")
}

main()
