# 242: Valid Anagram — dict 字符计数（键族 + 动态键 + has 守卫）
# 来源: LeetCode #242
# 期望输出:
#   true
#   false
def is_anagram(s:str, t:str) -> () {
	ns = strlen(s)  # = 等价于 <-
	nt <- strlen(t)
	ok = 1  # = 等价于 <-

	if (ns != nt) {
		0 -> ok
	} else {
		h = {}  # = 等价于 <-
		0 -> i
		while (i < ns) {
			char(s, i) -> c
			e <- has(h, c)

			if (e) {
				h.*c -> v
			} else {
				v = 0  # = 等价于 <-
			}
			set(h, c, v + 1) -> _
			i <- i + 1
		}
		0 -> i
		while (i < nt) {
			char(t, i) -> c
			e <- has(h, c)

			if (e) {
				h.*c -> v
			} else {
				v = 0  # = 等价于 <-
			}
			set(h, c, v - 1) -> _
			i + 1 -> i
		}
		0 -> i
		while (i < ns) {
			char(s, i) -> c
			h.*c -> v

			if (v != 0) {
				0 -> ok
				ns -> i
			}
			i <- i + 1
		}
	}
	if (ok) {
		print("true")
	} else {
		print("false")
	}
}

is_anagram("anagram", "nagaram")
is_anagram("rat", "car")
