# 001 Two Sum — brute force O(n^2)
# 期望输出: [0, 1]
def twoSum(nums, target:int) -> (i:int, j:int) {
    0 -> i
    len(nums) -> n
    while (i < n) {
        i + 1 -> j
        while (j < n) {
            at(nums, i) -> a
            at(nums, j) -> b
            a + b -> s
            s == target -> found
            if (found) {
                j -> j
            }
            j + 1 -> j
        }
        i + 1 -> i
    }
}
array(2, 7, 11, 15) -> nums
twoSum(nums, 9) -> a, b
print("[", a, ", ", b, "]")
a -> /two_sum_i
b -> /two_sum_j
