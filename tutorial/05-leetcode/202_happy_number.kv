# 202: Happy Number — 快乐数检测（循环或到1）
# 来源: LeetCode #202
# 期望输出:
#   1
def is_happy(n:int) -> (result:int) {
	0 -> slow
	fast <- n
	found = 0  # = 等价于 <-
	while (found == 0) {
		n -> x
		s <- 0
		while (x > 0) {
			d = x % 10  # = 等价于 <-
			d * d -> d2
			s <- s + d2
			x = x / 10  # = 等价于 <-
		}
		s -> n
		done <- n == 1

		if (done) {
			found = 1  # = 等价于 <-
			1 -> result
		}
	}
}

r <- is_happy(19)
print(r)
