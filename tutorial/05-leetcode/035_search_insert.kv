# 035: Search Insert Position — 二分查找插入位置
# 算法: 二分查找
# 来源: LeetCode #35
# 期望输出:
#   index = 2
def search_insert() -> () {
	a <- [1, 3, 5, 6]
	5 -> target
	len(a) -> n
	0 -> lo
	n - 1 -> hi
	0 -> pos
	while (lo <= hi) {
		lo + hi -> s
		s / 2 -> mid
		a[mid] -> mv
		mv == target -> eq

		if (eq) {
			mid -> pos
			hi + 1 -> lo
		} else {
			mv < target -> lt

			if (lt) {
				mid + 1 -> lo
			} else {
				mid - 1 -> hi
			}
		}
	}
	pos == 0 -> not_found

	if (not_found) {
		lo -> pos
	}

	print("index =", pos)
}

def main() -> () {
	search_insert()
}

main()
