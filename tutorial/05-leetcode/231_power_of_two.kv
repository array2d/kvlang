# 231: Power of Two — 判断是否为2的幂
# 来源: LeetCode #231
# 期望输出:
#   1
#   0
def is_power(n:int) -> (r:int) {
	result = 0  # = 等价于 <-
	n > 0 -> pos

	if (pos) {
		t <- 1
		while (t < n) {
			t = t * 2  # = 等价于 <-
		}
		t == n -> eq

		if (eq) {
			result <- 1
		}
	}

	r = result  # = 等价于 <-
}

is_power(16) -> r1
print(r1)
r2 <- is_power(18)
print(r2)
