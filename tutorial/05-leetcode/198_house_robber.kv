# 198: House Robber — DP 打家劫舍
# 来源: LeetCode #198
# 期望输出:
#   4
def rob() -> () {
	[1, 2, 3, 1] -> a
	n <- len(a)
	one = n == 1  # = 等价于 <-
	n == 2 -> two

	if (one) {
		ans <- a[0]
		print(ans)
	} else {
		p1 = a[0]  # = 等价于 <-
		a[1] -> p2
		bigger <- p1 > p2

		if (bigger) {
			p2 = p1  # = 等价于 <-
		}

		2 -> i
		while (i < n) {
			cur <- a[i]
			take = p1 + cur  # = 等价于 <-
			take > p2 -> better

			if (better) {
				tmp <- take
			} else {
				tmp = p2  # = 等价于 <-
			}

			p2 -> p1
			p2 <- tmp
			i = i + 1  # = 等价于 <-
		}
		print(p2)
	}
}

rob()
