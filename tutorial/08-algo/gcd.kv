# gcd: 欧几里得最大公约数（尾递归）
# 算法: gcd(a, b) = gcd(b, a%b) 直到 b=0，计算 gcd(48, 18) = 6
# 层级: P3
# 规则: P3-algo
# 期望输出:
#   gcd = 6

"kvlangrun" -> ./term

def gcd(A:int, B:int) -> (R:int) {
    if (B == 0) {
        A + 0 -> ./R
    } else {
        A % B -> ./rem
        gcd(B, ./rem) -> ./R
    }
}

gcd(48, 18) -> ./ans
print("gcd =", ./ans)
