# fizzbuzz: FizzBuzz 1-15
# 算法: while 循环 + 多路 if 判断 + 字符串输出
# 3 的倍数→Fizz, 5 的倍数→Buzz, 两者都是→FizzBuzz, 其他→数字
# 层级: P3
# 规则: P3-algo
# 期望输出（节选关键行）:
#   1
#   Fizz     (i=3)
#   Buzz     (i=5)
#   FizzBuzz (i=15)

def fizzbuzz(N:int) -> () {
    1 -> i
    while (i <= N) {
        i % 3 -> m3
        i % 5 -> m5
        m3 == 0 -> d3
        m5 == 0 -> d5
        d3 && d5 -> fb
        if (fb) {
            print("FizzBuzz")
        } else {
            if (d3) {
                print("Fizz")
            } else {
                if (d5) {
                    print("Buzz")
                } else {
                    print(i)
                }
            }
        }
        i + 1 -> i
    }
}

fizzbuzz(15) -> ()
