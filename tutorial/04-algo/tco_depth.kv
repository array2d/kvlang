# tco_depth: TCO 验证 TCO-1~TCO-2
# 期望输出:
#   sum = 5050
#   fact = 3628800
def sum_while(N:int) -> (total:int) {
	total = 0  # = 等价于 <-
	1 -> i
	while (i <= N) {
		total <- total + i
		i = i + 1  # = 等价于 <-
	}
}

def tailrec_fact(N:int, acc:int) -> (r:int) {
	if (N <= 1) {
		acc + 0 -> r
	} else {
		acc1 <- acc * N
		n1 = N - 1  # = 等价于 <-
		tailrec_fact(n1, acc1) -> r
	}
}

def main() -> () {
	s <- sum_while(100)
	print("sum =", s)
	f = tailrec_fact(10, 1)  # = 等价于 <-
	print("fact =", f)
	s -> /last_tco_sum
	/last_tco_fact <- f
}

main()
