# tco_depth: TCO 验证 TCO-1~TCO-2
# 期望输出:
#   sum = 5050
#   fact = 3628800
def sum_while(N:int) -> (total:int) {
	0 -> total
	1 -> i
	while (i <= N) {
		total + i -> total
		i + 1 -> i
	}
}

def tailrec_fact(N:int, acc:int) -> (r:int) {
	if (N <= 1) {
		acc + 0 -> r
	} else {
		acc * N -> acc1
		N - 1 -> n1
		tailrec_fact(n1, acc1) -> r
	}
}

def main() -> () {
	sum_while(100) -> s
	print("sum =", s)
	tailrec_fact(10, 1) -> f
	print("fact =", f)
	s -> /last_tco_sum
	f -> /last_tco_fact
}

main()
