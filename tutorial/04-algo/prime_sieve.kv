# prime_sieve: 试除法求质数（Rust The Book §3.5）
# 算法: 嵌套 while，找出 <=30 的质数
# 期望输出:
#   prime: 2
#   prime: 29
#   total primes up to 30 = 10
def prime_sieve(limit:int) -> () {
	print("primes up to", limit)
	count = 0  # = 等价于 <-
	2 -> n
	while (n <= limit) {
		is_prime <- 1
		d = 2  # = 等价于 <-
		while (d < n) {
			n % d -> rem
			divisible <- rem == 0

			if (divisible) {
				is_prime = 0  # = 等价于 <-
				n -> d
			} else {
				d <- d + 1
			}
		}

		if (is_prime) {
			print("  prime:", n)
			count = count + 1  # = 等价于 <-
		}

		n + 1 -> n
	}
	print("total primes up to", limit, "=", count)
	/last_primes <- count
}

prime_sieve(30)
