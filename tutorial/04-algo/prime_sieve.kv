# prime_sieve: 试除法求质数（Rust The Book §3.5）
# 算法: 嵌套 while，找出 <=30 的质数
# 期望输出:
#   prime: 2
#   prime: 29
#   total primes up to 30 = 10
def prime_sieve(limit:int) -> () {
	print("primes up to", limit)
	0 -> count
	2 -> n
	while (n <= limit) {
		1 -> is_prime
		2 -> d
		while (d < n) {
			n % d -> rem
			rem == 0 -> divisible

			if (divisible) {
				0 -> is_prime
				n -> d
			} else {
				d + 1 -> d
			}
		}

		if (is_prime) {
			print("  prime:", n)
			count + 1 -> count
		}

		n + 1 -> n
	}
	print("total primes up to", limit, "=", count)
	count -> /last_primes
}

prime_sieve(30)
