# prime_sieve: 试除法求质数（Rust The Book §3.5）
# 算法: 嵌套 while，找出 <=30 的质数
# 期望输出:
#   prime: 2
#   prime: 29
#   total primes up to 30 = 10

def prime_sieve(limit:int) -> () {
    print("primes up to", limit)

    count <- 0
    n <- 2

    while (n <= limit) {
        is_prime <- 1
        d <- 2

        while (d < n) {
            n % d -> rem
            rem == 0 -> divisible
            if (divisible) {
                is_prime <- 0
                d <- n                  # break
            } else {
                d <- d + 1
            }
        }

        if (is_prime) {
            print("  prime:", n)
            count <- count + 1
        }

        n <- n + 1
    }

    print("total primes up to", limit, "=", count)
    count -> /last_primes           # global
}

prime_sieve(30) -> ()
