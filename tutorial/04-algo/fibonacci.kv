# fibonacci: 迭代斐波那契数列
# 算法: while 循环 + 临时交换，计算 fib(10) = 55
# 期望输出:
#   fib = 55

def fibonacci(n:int) -> (result:int) {
    if (n <= 1) {
        n + 0 -> result
    } else {
        a <- 0
        b <- 1
        i <- 2
        while (i <= n) {
            c <- a + b
            b + 0 -> a
            c + 0 -> b
            i <- i + 1
        }
        b + 0 -> result
    }
}

fibonacci(10) -> ans
print("fib =", ans)
ans -> /last_fib                   # global
