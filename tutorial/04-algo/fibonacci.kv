# fibonacci: 迭代斐波那契数列
# 算法: while 循环 + 临时交换，计算 fib(10) = 55
# 期望输出:
#   fib = 55
def fibonacci(n:int64) -> (result:int64) {
	if (n <= 1) {
		n + 0 -> result
	} else {
		a <- 0
		b = 1  # = 等价于 <-
		2 -> i
		while (i <= n) {
			c <- a + b
			a = b + 0  # = 等价于 <-
			c + 0 -> b
			i <- i + 1
		}
		result = b + 0  # = 等价于 <-
	}
}

fibonacci(10) -> ans
print("fib =", ans)
/last_fib <- ans
