# collatz: Collatz 猜想步数
# 算法: while + 条件分支，start=27
# 期望输出:
#   steps = 111
def collatz(n:int) -> (steps:int) {
	0 -> steps
	while (n > 1) {
		n % 2 -> mod
		mod == 0 -> even

		if (even) {
			n / 2 -> n
		} else {
			n * 3 -> t
			t + 1 -> n
		}

		steps + 1 -> steps
	}
}

collatz(27) -> ans
print("steps =", ans)
ans -> /last_steps
