# collatz: Collatz 猜想步数
# 算法: while + 条件分支，start=27
# 期望输出:
#   steps = 111

def collatz(n:int) -> (steps:int) {
    steps <- 0
    while (n > 1) {
        n % 2 -> mod
        mod == 0 -> even
        if (even) {
            n <- n / 2
        } else {
            t <- n * 3
            n <- t + 1
        }
        steps <- steps + 1
    }
}

collatz(27) -> ans
print("steps =", ans)
ans -> /last_steps                  # global
