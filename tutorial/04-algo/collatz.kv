# collatz: Collatz 猜想步数
# 算法: while + 条件分支，start=27
# 期望输出:
#   steps = 111
def collatz(n:int) -> (steps:int) {
	n -> nv
	0 -> steps
	while (nv > 1) {
		mod <- nv % 2
		even = mod == 0  # = 等价于 <-

		if (even) {
			nv / 2 -> nv
		} else {
			t <- nv * 3
			nv = t + 1  # = 等价于 <-
		}

		steps + 1 -> steps
	}
}

ans <- collatz(27)
print("steps =", ans)
/last_steps = ans  # = 等价于 <-
