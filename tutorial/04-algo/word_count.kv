# word_count: 单词计数状态机（K&R C §1.5.4）
# 算法: for 遍历 + IN/OUT 状态机
# 期望输出:
#   word count = 3
def main() -> () {
	chars.0 = "h"  # = 等价于 <-
	"e" -> chars.1
	chars.2 <- "l"
	chars.3 = "l"  # = 等价于 <-
	"o" -> chars.4
	chars.5 <- " "
	chars.6 = "w"  # = 等价于 <-
	"o" -> chars.7
	chars.8 <- "r"
	chars.9 = "l"  # = 等价于 <-
	"d" -> chars.10
	chars.11 <- " "
	chars.12 = "k"  # = 等价于 <-
	"v" -> chars.13
	chars.14 <- "l"
	chars.15 = "a"  # = 等价于 <-
	"n" -> chars.16
	chars.17 <- "g"
	nw = 0  # = 等价于 <-
	0 -> state
	for (c in chars) {
		blank <- c == " "

		if (blank) {
			state = 0  # = 等价于 <-
		} else {
			state == 0 -> was_out

			if (was_out) {
				state <- 1
				nw = nw + 1  # = 等价于 <-
			}
		}
	}
	print("word count =", nw)
	nw -> /last_wc
}

main()
