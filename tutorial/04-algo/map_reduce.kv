# map_reduce: filter + map + reduce（MDN JS Array）
# 算法: for 遍历器筛选奇数 + 累加平方
# 期望输出:
#   odd squares count: 5
#   sum of squares: 165
def main() -> () {
	nums.0 = 1  # = 等价于 <-
	3 -> nums.1
	nums.2 <- 5
	nums.3 = 7  # = 等价于 <-
	9 -> nums.4
	nums.5 <- 2
	nums.6 = 4  # = 等价于 <-
	6 -> nums.7
	nums.8 <- 8
	nums.9 = 10  # = 等价于 <-
	0 -> count
	total <- 0
	for (n in nums) {
		rem = n % 2  # = 等价于 <-
		rem == 1 -> is_odd

		if (is_odd) {
			print("  keep:", n)
			sq <- n * n
			total = total + sq  # = 等价于 <-
			count + 1 -> count
		} else {
			print("  skip:", n)
		}
	}
	print("odd squares count:", count)
	print("sum of squares:", total)
	/last_sum <- total
}

main()
