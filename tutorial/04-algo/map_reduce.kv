# map_reduce: filter + map + reduce（MDN JS Array）
# 算法: for 遍历器筛选奇数 + 累加平方
# 期望输出:
#   odd squares count: 5
#   sum of squares: 165

def main() -> () {
    1  -> nums/0
    3  -> nums/1
    5  -> nums/2
    7  -> nums/3
    9  -> nums/4
    2  -> nums/5
    4  -> nums/6
    6  -> nums/7
    8  -> nums/8
    10 -> nums/9

    count <- 0
    total <- 0
    for (n in nums) {
        n % 2 -> rem
        rem == 1 -> is_odd
        if (is_odd) {
            print("  keep:", n)
            sq <- n * n
            total <- total + sq
            count <- count + 1
        } else {
            print("  skip:", n)
        }
    }

    print("odd squares count:", count)
    print("sum of squares:", total)
    total -> /last_sum               # global
}

main() -> ()
