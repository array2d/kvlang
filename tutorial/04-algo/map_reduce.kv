# map_reduce: filter + map + reduce 函数式模式（MDN JS Array）
# 算法: for 遍历器筛选奇数 (filter) + 求平方累加 (map+reduce 合一)
# 来源: MDN JavaScript Array.prototype.map / filter / reduce
# 层级: P3
# 规则: P3-algo
# 期望输出:
#   odd squares count: 5
#   sum of squares: 165

def main() -> () {
    1  -> nums/0
    3  -> nums/1
    5  -> nums/2
    7  -> nums/3
    9  -> nums/4
    2  -> nums/5
    4  -> nums/6
    6  -> nums/7
    8  -> nums/8
    10 -> nums/9

    0 -> count
    0 -> total
    for (n in nums) {
        n % 2 -> rem
        rem == 1 -> is_odd
        if (is_odd) {
            print("  keep:", n)
            n * n -> sq
            total + sq -> total
            count + 1 -> count
        } else {
            print("  skip:", n)
        }
    }

    print("odd squares count:", count)
    print("sum of squares:", total)
}

main() -> ()
