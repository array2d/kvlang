# scope_isolation: 帧隔离验证 SI-1~SI-3
# 期望输出:
#   PASS SI-1a: x=5 returns 5
#   PASS SI-1b: x=10 returns 10
#   PASS SI-2a: S= 8 D= 2
#   PASS SI-2b: S= 15 D= 5
#   PASS SI-3: chain = 10
def id_val(x:int64) -> (R:int64) {
	x + 0 -> R
}

def sum_diff(A:int64, B:int64) -> (S:int64, D:int64) {
	S <- A + B
	D = A - B  # = 等价于 <-
}

def chain_call(a:int64, b:int64) -> (r:int64) {
	a + b -> r
}

def main() -> () {
	v1 <- id_val(5)
	print("PASS SI-1a: x=5 returns", v1)
	v2 = id_val(10)  # = 等价于 <-
	print("PASS SI-1b: x=10 returns", v2)
	sum_diff(5, 3) -> (s1, d1)
	print("PASS SI-2a: S=", s1, "D=", d1)
	sum_diff(10, 5) -> (s2, d2)
	print("PASS SI-2b: S=", s2, "D=", d2)
	chain_call(7, 3) -> c
	print("PASS SI-3: chain =", c)
	/last_chain <- c
}

main()
