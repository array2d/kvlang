# fizzbuzz: FizzBuzz 1-15
# 算法: while 循环 + 多路 if 判断
# 期望输出:
#   1
#   Fizz
#   Buzz
#   FizzBuzz

def fizzbuzz(N:int) -> () {
    i <- 1
    while (i <= N) {
        i % 3 -> m3
        i % 5 -> m5
        m3 == 0 -> d3
        m5 == 0 -> d5
        d3 && d5 -> fb
        if (fb) {
            print("FizzBuzz")
        } else {
            if (d3) {
                print("Fizz")
            } else {
                if (d5) {
                    print("Buzz")
                } else {
                    print(i)
                }
            }
        }
        i <- i + 1
    }
    N -> /last_n                    # global
}

fizzbuzz(15) -> ()
