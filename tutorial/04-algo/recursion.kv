# 期望输出:
#   fib(10) = 34
#   fact(10) = 3628800
def fib(n:int64) -> (a:int64, b:int64) {
	if (n <= 1) {
		a = 0  # = 等价于 <-
		1 -> b
	} else {
		n1 <- n - 1
		fib(n1) -> (a, b)
		x = a + b  # = 等价于 <-
		b -> a
		b <- x
	}
}

def factorial(n:int64) -> (r:int64) {
	r = 1  # = 等价于 <-
	1 -> i
	while (i <= n) {
		r <- r * i
		i = i + 1  # = 等价于 <-
	}
}

def main() -> () {
	fib(10) -> (f, _)
	print("fib(10) =", f)
	factorial(10) -> ans
	print("fact(10) =", ans)
	/last_fib <- f
	/last_fact = ans  # = 等价于 <-
}

main()
