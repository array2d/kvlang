# 期望输出:
#   fib(10) = 34
#   fact(10) = 3628800

def fib(n: int) -> (a: int, b: int) {
    if (n <= 1) {
        0 -> a
        1 -> b
    } else {
        n1 <- n - 1                 # <- style
        fib(n1) -> a, b
        x <- a + b
        b -> a
        x -> b
    }
}

def factorial(n: int) -> (r: int) {
    r <- 1
    i <- 1
    while (i <= n) {
        r <- r * i
        i <- i + 1
    }
}

def main() -> () {
    fib(10) -> f, _
    print("fib(10) =", f)

    factorial(10) -> ans
    print("fact(10) =", ans)

    f -> /last_fib                  # global
    ans -> /last_fact               # global
}

main() -> ()
