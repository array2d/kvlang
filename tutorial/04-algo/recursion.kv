# 期望输出:
#   fib(10) = 55
#   fact(10) = 3628800

# 04-algo recursion: recursive functions with TCO
# Run: kvlang tutorial/07-recursion/

def fib(n: int) -> (a: int, b: int) {
    if (n <= 1) {
        0 -> a
        1 -> b
    } else {
        n - 1 -> n1
        fib(n1) -> a, b
        a + b -> x
        b -> a
        x -> b
    }
}

def fact(n: int, acc: int) -> (r: int) {
    if (n <= 0) {
        acc -> r
    } else {
        n - 1    -> n1
        acc * n  -> acc1
        fact(n1, acc1) -> r
    }
}

def main() -> () {
    fib(10) -> _, result
    print("fib(10) =", result)

    fact(10, 1) -> f
    print("fact(10) =", f)     // 3628800
}

main() -> ()
