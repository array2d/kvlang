# classify: 成绩分档
# 算法: 嵌套 if，score=85 → grade=B
# 期望输出:
#   grade = B
def classify(score:int) -> (grade:string) {
	if (score >= 90) {
		grade = "A"  # = 等价于 <-
	} else {
		if (score >= 80) {
			"B" -> grade
		} else {
			if (score >= 70) {
				grade <- "C"
			} else {
				if (score >= 60) {
					grade = "D"  # = 等价于 <-
				} else {
					"F" -> grade
				}
			}
		}
	}
}

ans <- classify(85)
print("grade =", ans)
/last_grade = ans  # = 等价于 <-
