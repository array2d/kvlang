# 07-recursion: recursive functions with TCO
# Run: kvlang tutorial/07-recursion/main.kv

"kvlangrun" -> ./term

def fib(n: int) -> (a: int, b: int) {
    if (n <= 1) {
        0 -> ./a
        1 -> ./b
    } else {
        fib(n - 1) -> ./a, ./b
        ./a + ./b -> ./x
        ./b -> ./a
        ./x -> ./b
    }
}

def fact(n: int, acc: int) -> (r: int) {
    if (n <= 0) {
        acc -> ./r
    } else {
        fact(n - 1, acc * n) -> ./r
    }
}

def main() -> () {
    fib(10) -> ./_, ./result
    print("fib(10) =", ./result)

    fact(10, 1) -> ./f
    print("fact(10) =", ./f)     // 3628800
}
main() -> ()
