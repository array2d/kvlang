# 069: Sqrt(x) — 二分求平方根
# 来源: LeetCode #69
# 期望输出:
#   2
def my_sqrt(x:int) -> () {
	lo <- 0
	hi = x  # = 等价于 <-
	0 -> ans
	while (lo <= hi) {
		s <- lo + hi
		mid = s / 2  # = 等价于 <-
		mid * mid -> sq
		ok <- sq <= x

		if (ok) {
			ans = mid  # = 等价于 <-
			mid + 1 -> lo
		} else {
			hi <- mid - 1
		}
	}
	print(ans)
}

my_sqrt(4)
