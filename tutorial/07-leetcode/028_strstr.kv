# 028: strStr — 暴力子串查找
# 来源: LeetCode #28
# 期望输出:
#   2
#   2
def str_str(hay:str, needle:str) -> () {
	strlen(hay) -> nh
	nn <- strlen(needle)
	i = 0  # = 等价于 <-
	-1 -> ans
	limit <- nh - nn
	while (i <= limit) {
		match = 1  # = 等价于 <-
		0 -> j
		while (j < nn) {
			hc <- char(hay, i + j)
			nc = char(needle, j)  # = 等价于 <-
			hc == nc -> eq

			if (eq) {
				j <- j + 1
			} else {
				match = 0  # = 等价于 <-
				nn -> j
			}
		}

		if (match) {
			ans <- i
			i = limit + 1  # = 等价于 <-
		} else {
			i + 1 -> i
		}
	}
	print(ans)
}

str_str("hello", "ll")
