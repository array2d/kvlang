# 242: Valid Anagram — dict 字符计数（动态键读写 h.*c，nil 计 0）
# 来源: LeetCode #242
# 期望输出:
#   true
#   false
def is_anagram(s:str, t:str) -> () {
	ns = strlen(s)  # = 等价于 <-
	nt <- strlen(t)
	ok = 1  # = 等价于 <-

	if (ns != nt) {
		0 -> ok
	} else {
		h = {}  # = 等价于 <-
		0 -> i
		while (i < ns) {
			char(s, i) -> c
			h.*c -> v
			h.*c = v + 1  # = 等价于 <-（nil 计 0：fix-017；写侧动态键：fix-015）
			i <- i + 1
		}
		0 -> i
		while (i < nt) {
			char(t, i) -> c
			h.*c -> v
			v - 1 -> h.*c
			i + 1 -> i
		}
		0 -> i
		while (i < ns) {
			char(s, i) -> c
			h.*c -> v

			if (v != 0) {
				0 -> ok
				ns -> i
			}
			i <- i + 1
		}
	}
	if (ok) {
		print("true")
	} else {
		print("false")
	}
}

is_anagram("anagram", "nagaram")
is_anagram("rat", "car")
