# 349: Intersection of Two Arrays — O(n²) 暴力
# 来源: LeetCode #349
# 期望输出:
#   2
def intersection() -> () {
	a:int = [1, 2, 2, 1]  # = 等价于 <-
	len(a) -> na
	b:int <- [2, 2]
	nb = len(b)  # = 等价于 <-
	[0, 0] -> r:int
	idx <- 0
	count = 0  # = 等价于 <-
	0 -> i
	while (i < na) {
		av <- a[i]
		j = 0  # = 等价于 <-
		0 -> found
		while (j < nb) {
			bv <- b[j]
			match = av == bv  # = 等价于 <-

			if (match) {
				1 -> found
				j <- nb
			} else {
				j = j + 1  # = 等价于 <-
			}
		}

		if (found) {
			r[idx] <- av
			idx + 1 -> idx
			count <- count + 1
		}

		i = i + 1  # = 等价于 <-
	}
	r[0] -> v
	print(v)
}

intersection()
