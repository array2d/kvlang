# 169: Majority Element — Boyer-Moore 投票算法
# 算法: 计数抵消，多数元素必然存活
# 来源: LeetCode #169
# 期望输出:
#   3
def majority() -> () {
	a:int64 = [3, 2, 3]  # = 等价于 <-
	len(a) -> n
	candidate <- a[0]
	count = 1  # = 等价于 <-
	1 -> i
	while (i < n) {
		x <- a[i]
		reset = count == 0  # = 等价于 <-

		if (reset) {
			x -> candidate
			count <- 1
		} else {
			match = x == candidate  # = 等价于 <-

			if (match) {
				count + 1 -> count
			} else {
				count <- count - 1
			}
		}

		i = i + 1  # = 等价于 <-
	}
	print(candidate)
}

majority()
