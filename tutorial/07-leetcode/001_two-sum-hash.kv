# 001: Two Sum — O(n) hash map (h.*key 动态解引用)
# 来源: LeetCode #1
# 期望输出:
#   [ 0 , 1 ]
def two_sum(nums, target:int) -> () {
	n <- len(nums)
	i = 0  # = 等价于 <-
	"/tmp" -> h
	while (i < n) {
		x <- nums[i]
		need = target - x  # = 等价于 <-
		h[need] -> j
		found <- j

		if (found) {
			k = j - 1  # = 等价于 <-
			print("[", k, ",", i, "]")
			n -> i
		} else {
			v <- i + 1
			_ = set(h, x, v)  # = 等价于 <-
			i + 1 -> i
		}
	}
}

two_sum(array(2, 7, 11, 15), 9)
