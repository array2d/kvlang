# 217: Contains Duplicate — O(n) hash set
# 来源: LeetCode #217
# 期望输出:
#   true
#   false
def has_dup(a) -> () {
	len(a) -> n
	found <- 0
	i = 0  # = 等价于 <-
	while (i < n) {
		a[i] -> x
		v <- "/seen"[x]
		exists = v  # = 等价于 <-

		if (exists) {
			1 -> found
			i <- n
		} else {
			_ = set("/seen", x, 1)  # = 等价于 <-
			i + 1 -> i
		}
	}
	f <- found

	if (f) {
		print("true")
	} else {
		print("false")
	}
}

def no_dup() -> () {
	a = [1, 2, 3, 4]  # = 等价于 <-
	len(a) -> n
	found <- 0
	i = 0  # = 等价于 <-
	while (i < n) {
		a[i] -> x
		v <- "/seen2"[x]
		exists = v  # = 等价于 <-

		if (exists) {
			1 -> found
			i <- n
		} else {
			_ = set("/seen2", x, 1)  # = 等价于 <-
			i + 1 -> i
		}
	}
	f <- found

	if (f) {
		print("true")
	} else {
		print("false")
	}
}

def main() -> () {
	has_dup(array(1, 2, 3, 1))
	no_dup()
}

main()
