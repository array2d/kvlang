# 441: Arranging Coins — 二分查找完整行数
# 来源: LeetCode #441
# 期望输出:
#   2
def arrange(n:int64) -> () {
	lo = 1  # = 等价于 <-
	n -> hi
	ans <- 0
	while (lo <= hi) {
		s = lo + hi  # = 等价于 <-
		s / 2 -> mid
		m2 <- mid * mid
		total = m2 + mid  # = 等价于 <-
		total / 2 -> t
		ok <- t <= n

		if (ok) {
			ans = mid  # = 等价于 <-
			mid + 1 -> lo
		} else {
			hi <- mid - 1
		}
	}
	print(ans)
}

arrange(5)
