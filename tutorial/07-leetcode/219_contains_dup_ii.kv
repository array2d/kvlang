# 219: Contains Duplicate II — hash 记录最近下标（存 i+1，nil 判 >0）
# 来源: LeetCode #219
# 期望输出:
#   true
#   false
def near_dup(nums:int, k:int) -> () {
	n <- len(nums)
	h = {}  # = 等价于 <-
	found = 0  # = 等价于 <-
	0 -> i
	while (i < n) {
		nums[i] -> x
		h.*x -> j

		if (j > 0) {
			d <- i - j + 1

			if (d <= k) {
				1 -> found
				n -> i
			}
		}
		if (found == 0) {
			set(h, x, i + 1) -> _
		}
		i <- i + 1
	}
	if (found) {
		print("true")
	} else {
		print("false")
	}
}

a1:int = [1, 2, 3, 1]
near_dup(a1, 3)
a2:int = [1, 2, 3, 1, 2, 3]
near_dup(a2, 2)
