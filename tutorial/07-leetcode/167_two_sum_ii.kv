# 167: Two Sum II — 有序数组双指针
# 来源: LeetCode #167
# 期望输出:
#   [ 1 , 2 ]
def two_sum_ii() -> () {
	[2, 7, 11, 15] -> a:int
	target <- 9
	n = len(a)  # = 等价于 <-
	0 -> l
	r <- n - 1
	while (l < r) {
		lv = a[l]  # = 等价于 <-
		a[r] -> rv
		s <- lv + rv
		hit = s == target  # = 等价于 <-

		if (hit) {
			l + 1 -> i1
			i2 <- r + 1
			print("[", i1, ",", i2, "]")
			l = n  # = 等价于 <-
		} else {
			s < target -> lt

			if (lt) {
				l <- l + 1
			} else {
				r = r - 1  # = 等价于 <-
			}
		}
	}
}

two_sum_ii()
