# 001: Two Sum — 数组参数版
# 来源: LeetCode #1
# 期望输出:
#   [ 0 , 1 ]
#   [-1, -1]
def two_sum(nums:int64, target:int64) -> () {
	n <- len(nums)
	found = 0  # = 等价于 <-
	0 -> i
	while (i < n) {
		j <- 0
		while (j < n) {
			sk = i == j  # = 等价于 <-

			if (sk) {
				j + 1 -> j
			} else {
				x <- nums[i]
				y = nums[j]  # = 等价于 <-
				x + y -> s
				hit <- s == target

				if (hit) {
					print("[", i, ",", j, "]")
					found = 1  # = 等价于 <-
					n -> i
					j <- n
				} else {
					j = j + 1  # = 等价于 <-
				}
			}
		}
		i + 1 -> i
	}
	nf <- found == 0

	if (nf) {
		print("[-1, -1]")
	}
}

a1:int64 = [2, 7, 11, 15]
two_sum(a1, 9)
a2:int64 = [1, 2, 3]
two_sum(a2, 99)
