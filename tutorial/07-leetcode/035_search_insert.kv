# 035: Search Insert Position — 二分查找插入位置
# 算法: 二分查找
# 来源: LeetCode #35
# 期望输出:
#   index = 2
def search_insert() -> () {
	a:int = [1, 3, 5, 6]  # = 等价于 <-
	5 -> target
	n <- len(a)
	lo = 0  # = 等价于 <-
	n - 1 -> hi
	pos <- 0
	while (lo <= hi) {
		s = lo + hi  # = 等价于 <-
		s / 2 -> mid
		mv <- a[mid]
		eq = mv == target  # = 等价于 <-

		if (eq) {
			mid -> pos
			lo <- hi + 1
		} else {
			lt = mv < target  # = 等价于 <-

			if (lt) {
				mid + 1 -> lo
			} else {
				hi <- mid - 1
			}
		}
	}
	not_found = pos == 0  # = 等价于 <-

	if (not_found) {
		lo -> pos
	}

	print("index =", pos)
}

search_insert()
