# 168: Excel Sheet Column Title — 数字转26进制列名
# 来源: LeetCode #168
# 期望输出:
#   65
#   66
def convert(n:int) -> () {
	# Build reversed chars into array, then print in reverse
	[0, 0, 0, 0, 0] -> a:int
	idx <- 0
	num = n  # = 等价于 <-
	while (num > 0) {
		num - 1 -> n1
		r <- n1 % 26
		ch = 65 + r  # = 等价于 <-
		a[idx] <- ch
		idx + 1 -> idx
		num <- n1 / 26
	}
	k = idx - 1  # = 等价于 <-
	while (k >= 0) {
		a[k] -> v
		print(v)
		k <- k - 1
	}
}

convert(28)
