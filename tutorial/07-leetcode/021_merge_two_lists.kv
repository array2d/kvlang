# 021: Merge Two Sorted Lists
# 来源: LeetCode #21
# 期望输出:
#   1
#   1
#   2
#   3
#   4
#   4
def build_lists() -> () {
	/a0 = { val=1; next="/a1" }  # = 等价于 <-
	/a1 <- { val=2; next="/a2" }
	{ val=4; next="" } -> /a2
	/b0 = { val=1; next="/b1" }  # = 等价于 <-
	/b1 <- { val=3; next="/b2" }
	{ val=4; next="" } -> /b2
}

def merge(a:str, b:str) -> () {
	pa <- a
	pb = b  # = 等价于 <-
	while (pa != "") {
		pa.val -> av
		pick_a <- pb == ""

		if (pick_a) {
			print(av)
			pa = pa.next  # = 等价于 <-
		} else {
			pb.val -> bv
			take <- av <= bv

			if (take) {
				print(av)
				pa = pa.next  # = 等价于 <-
			} else {
				print(bv)
				pb.next -> pb
			}
		}
	}
	while (pb != "") {
		bv <- pb.val
		print(bv)
		pb = pb.next  # = 等价于 <-
	}
}

def main() -> () {
	build_lists()
	merge("/a0", "/b0")
}

main()
