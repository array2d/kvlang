# 013 Roman to Integer
# 期望输出: 58, 1994
def romanToInt(s:string) -> (val:int64) {
	0 -> val
	i <- 0
	n = len(s)  # = 等价于 <-
	"" -> prev
	while (i < n) {
		c <- s[i]
		isI = c == "I"  # = 等价于 <-
		c == "V" -> isV
		isX <- c == "X"
		isL = c == "L"  # = 等价于 <-
		c == "C" -> isC
		isD <- c == "D"
		pI = prev == "I"  # = 等价于 <-
		prev == "X" -> pX
		pC <- prev == "C"

		if (isI) {
			val = val + 1  # = 等价于 <-
		}

		if (isV) {
			val + 5 -> val
		}

		if (isX) {
			val <- val + 10
		}

		if (isL) {
			val = val + 50  # = 等价于 <-
		}

		if (isC) {
			val + 100 -> val
		}

		if (isD) {
			val <- val + 500
		}

		subI = pI  # = 等价于 <-
		pX -> subX
		subC <- pC

		if (isV) {
			if (subI) {
				val = val - 2  # = 等价于 <-
			}
		}

		if (isX) {
			if (subI) {
				val - 2 -> val
			}
		}

		if (isL) {
			if (subX) {
				val <- val - 20
			}
		}

		if (isC) {
			if (subX) {
				val = val - 20  # = 等价于 <-
			}
		}

		if (isD) {
			if (subC) {
				val - 200 -> val
			}
		}

		prev <- c
		i = i + 1  # = 等价于 <-
	}
}

romanToInt("LVIII") -> a
print("LVIII =", a)
b <- romanToInt("MCMXCIV")
print("MCMXCIV =", b)
/roman_lviii = a  # = 等价于 <-
