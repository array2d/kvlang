# 033: Search in Rotated Sorted Array
# 算法: 二分查找 + 半区判断
# 来源: LeetCode #33
# 期望输出:
#   4
def search() -> () {
	a <- [4, 5, 6, 7, 0, 1, 2]
	n = len(a)  # = 等价于 <-
	0 -> target
	lo <- 0
	hi = n - 1  # = 等价于 <-
	-1 -> result
	while (lo <= hi) {
		s <- lo + hi
		mid = s / 2  # = 等价于 <-
		a[mid] -> mv
		eq <- mv == target

		if (eq) {
			result = mid  # = 等价于 <-
			hi + 1 -> lo
		} else {
			lv <- a[lo]
			rv = a[hi]  # = 等价于 <-
			lv <= mv -> left_sorted

			if (left_sorted) {
				t1 <- lv <= target
				t2 = target < mv  # = 等价于 <-

				if (t1 && t2) {
					mid - 1 -> hi
				} else {
					lo <- mid + 1
				}
			} else {
				t3 = mv <= target  # = 等价于 <-
				target <= rv -> t4

				if (t3 && t4) {
					lo <- mid + 1
				} else {
					hi = mid - 1  # = 等价于 <-
				}
			}
		}
	}
	print(result)
}

search()
