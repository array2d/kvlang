# 507: Perfect Number
# 来源: LeetCode #507
# 期望输出:
#   1
def is_perfect(n:int64) -> () {
	sum = 1  # = 等价于 <-
	2 -> i
	sq <- i * i
	while (sq <= n) {
		rem = n % i  # = 等价于 <-
		rem == 0 -> div

		if (div) {
			sum <- sum + i
			j = n / i  # = 等价于 <-
			sum + j -> sum
		}

		i <- i + 1
		sq = i * i  # = 等价于 <-
	}
	sum == n -> ok

	if (ok) {
		print(1)
	} else {
		print(0)
	}
}

is_perfect(28)
