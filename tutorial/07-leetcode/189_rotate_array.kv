# 189: Rotate Array — 三次反转旋转
# 算法: reverse(0,n-1), reverse(0,k-1), reverse(k,n-1)
# 来源: LeetCode #189
# 期望输出:
#   5
#   6
#   7
#   1
#   2
#   3
#   4
def swap(a_len:int64, lo:int64, hi:int64) -> () {
	a_len -> a_lenv
	lo -> lov
	hi -> hiv
	while (lov < hiv) {
		a[lov] -> t
		u <- a[hiv]
		a[lov] <- u
		a[hiv] <- t
		lov = lov + 1  # = 等价于 <-
		hiv - 1 -> hiv
	}
}

def rotate() -> () {
	a:int64 <- [1, 2, 3, 4, 5, 6, 7]
	n = len(a)  # = 等价于 <-
	3 -> k
	k_eff <- k % n
	# reverse all
	lo = 0  # = 等价于 <-
	n - 1 -> hi
	while (lo < hi) {
		t <- a[lo]
		u = a[hi]  # = 等价于 <-
		a[lo] <- u
		a[hi] <- t
		lo + 1 -> lo
		hi <- hi - 1
	}
	# reverse first k
	lo2 = 0  # = 等价于 <-
	k_eff - 1 -> hi2
	while (lo2 < hi2) {
		t2 <- a[lo2]
		u2 = a[hi2]  # = 等价于 <-
		a[lo2] <- u2
		a[hi2] <- t2
		lo2 + 1 -> lo2
		hi2 <- hi2 - 1
	}
	# reverse last n-k
	lo3 = k_eff  # = 等价于 <-
	n - 1 -> hi3
	while (lo3 < hi3) {
		t3 <- a[lo3]
		u3 = a[hi3]  # = 等价于 <-
		a[lo3] <- u3
		a[hi3] <- t3
		lo3 + 1 -> lo3
		hi3 <- hi3 - 1
	}
	j = 0  # = 等价于 <-
	while (j < n) {
		a[j] -> v
		print(v)
		j <- j + 1
	}
}

rotate()
