# 014: Longest Common Prefix — 逐字符比较
# 来源: LeetCode #14
# 期望输出:
#   fl
def lcp() -> () {
	"flower" -> a
	b <- "flow"
	c = "flight"  # = 等价于 <-
	strlen(a) -> na
	nb <- strlen(b)
	nc = strlen(c)  # = 等价于 <-
	0 -> i
	ok <- 1
	while (ok) {
		ca = i < na  # = 等价于 <-
		i < nb -> cb
		cc <- i < nc
		all_ok = ca && cb && cc  # = 等价于 <-

		if (all_ok) {
			char(a, i) -> va
			vb <- char(b, i)
			vc = char(c, i)  # = 等价于 <-
			va == vb -> ab
			bc <- vb == vc
			match = ab && bc  # = 等价于 <-

			if (match) {
				i + 1 -> i
			} else {
				ok <- 0
			}
		} else {
			ok = 0  # = 等价于 <-
		}
	}
	slice(a, 0, i) -> ans
	print(ans)
}

lcp()
