# 034: Find First and Last Position — 二分查找区间
# 算法: 两次二分分别找左边界和右边界
# 来源: LeetCode #34
# 期望输出:
#   [ 3 , 4 ]
def search_range() -> () {
	[5, 7, 7, 8, 8, 10] -> a:int64
	n <- len(a)
	target = 8  # = 等价于 <-
	# find left
	0 -> lo
	hi <- n - 1
	left = -1  # = 等价于 <-
	while (lo <= hi) {
		lo + hi -> s
		mid <- s / 2
		mv = a[mid]  # = 等价于 <-
		mv < target -> lt

		if (lt) {
			lo <- mid + 1
		} else {
			left = mid  # = 等价于 <-
			mid - 1 -> hi
		}
	}
	# find right  
	lo2 <- 0
	hi2 = n - 1  # = 等价于 <-
	-1 -> right
	while (lo2 <= hi2) {
		s2 <- lo2 + hi2
		mid2 = s2 / 2  # = 等价于 <-
		a[mid2] -> mv2
		gt <- mv2 > target

		if (gt) {
			hi2 = mid2 - 1  # = 等价于 <-
		} else {
			mid2 -> right
			lo2 <- mid2 + 1
		}
	}
	print("[", left, ",", right, "]")
}

search_range()
