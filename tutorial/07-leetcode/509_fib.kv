# 509: Fibonacci Number — 迭代斐波那契
# 来源: LeetCode #509
# 期望输出:
#   55
def fib(n:int64) -> () {
	base <- n <= 1

	if (base) {
		print(n)
	} else {
		a = 0  # = 等价于 <-
		1 -> b
		i <- 2
		while (i <= n) {
			c = a + b  # = 等价于 <-
			b -> a
			b <- c
			i = i + 1  # = 等价于 <-
		}
		print(c)
	}
}

fib(10)
