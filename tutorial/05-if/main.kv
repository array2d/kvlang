# 05-if: conditional logic
# Run: kvlang tutorial/05-if/

def abs(x: int) -> (r: int) {
    if (x < 0) {
        -x -> r
    } else {
        x -> r
    }
}

def main() -> () {
    abs(-5) -> a
    print("abs(-5) =", a)      // 5

    abs(3) -> b
    print("abs(3) =", b)       // 3

    true && false -> and_r
    print("true && false =", and_r)   // false

    true || false -> or_r
    print("true || false =", or_r)    // true

    !true -> not_r
    print("!true =", not_r)           // false
}

main() -> ()
