# precision: 数字精度与类型提升
# 语义: int 与 float 是语言面两种数字字面量（运行时 XValue 另有 int8~uint64/float32 等 kind）。
#       int op int → 原生 int64 运算与比较，绝不经 float64 中转（fix-020，对齐 C/Go/Rust）；
#       任一侧 float → float64 提升（混合比较为 C 式 double 提升）
# 期望输出:
#   5
#   5.5
#   3.0
#   3
#   -4
#   3.5
#   1
#   3
#   7.0
#   1000.0
#   0.025
#   0.30000000000000004
#   true
#   9223372036854775807
#   9223372036854775806
#   9007199254740993
#   false
def main() -> () {
	a = 2 + 3  # = 等价于 <-
	print(a)
	b <- 2 + 3.5
	print(b)
	1.5 * 2 -> c
	print(c)

	q = 7 / 2  # = 等价于 <-（整除：两侧均 int）
	print(q)
	-9 / 2 -> qz
	print(qz)
	fq <- 7.0 / 2
	print(fq)
	r = 7 % 3  # = 等价于 <-
	print(r)

	ti <- int(3.99)
	print(ti)
	float(7) -> tf
	print(tf)

	sci = 1e3  # = 等价于 <-（科学计数法字面量恒为 float）
	print(sci)
	small <- 2.5e-2
	print(small)

	0.1 + 0.2 -> sum
	print(sum)

	eq = 3 == 3.0  # = 等价于 <-（跨类型数值比较：值提升后相等）
	print(eq)

	big <- 9223372036854775807
	print(big)

	big - 1 -> bm
	print(bm)
	precise = 9007199254740993 + 0  # = 等价于 <-（2^53+1：int 算术不经 float，精度保真）
	print(precise)
	same <- big == 9223372036854775806
	print(same)
}

main()
