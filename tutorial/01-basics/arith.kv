# 期望输出:
#   add: 13
#   pow: 32
#   sqrt: 12
def main() -> () {
	10 + 3 -> add_r
	print("add:", add_r)
	10 - 3 -> sub_r
	print("sub:", sub_r)
	10 * 3 -> mul_r
	print("mul:", mul_r)
	10 / 3 -> div_r
	print("div:", div_r)
	pow(2, 5) -> pow_r
	print("pow:", pow_r)
	sqrt(144) -> sqrt_r
	print("sqrt:", sqrt_r)
	0 -> /ops_count
	/ops_count + 6 -> /ops_count
}

main()
