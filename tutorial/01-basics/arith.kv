# 期望输出:
#   add: 13
#   pow: 32
#   sqrt: 12

def main() -> () {
    10 + 3 -> add_r                 # -> style: expression -> slot
    print("add:", add_r)

    10 - 3 -> sub_r
    print("sub:", sub_r)

    mul_r <- 10 * 3                 # <- style: slot <- expression
    print("mul:", mul_r)

    div_r <- 10 / 3
    print("div:", div_r)

    pow_r <- pow(2, 5)
    print("pow:", pow_r)

    sqrt_r <- sqrt(144)
    print("sqrt:", sqrt_r)

    0 -> /ops_count                 # global: track operation count
    /ops_count + 6 -> /ops_count    # 6 operations performed
}

main() -> ()
