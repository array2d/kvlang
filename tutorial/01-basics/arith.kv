# 期望输出:
#   add: 13
#   pow: 32
#   sqrt: 12
def main() -> () {
	10 + 3 -> add_r
	print("add:", add_r)
	sub_r <- 10 - 3
	print("sub:", sub_r)
	mul_r = 10 * 3  # = 等价于 <-
	print("mul:", mul_r)
	10 / 3 -> div_r
	print("div:", div_r)
	pow_r <- pow(2, 5)
	print("pow:", pow_r)
	sqrt_r = sqrt(144)  # = 等价于 <-
	print("sqrt:", sqrt_r)
	0 -> /ops_count
	/ops_count <- /ops_count + 6
}

main()
