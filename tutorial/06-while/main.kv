# 06-while: while loops, break, and continue
# Run: kvlang tutorial/06-while/

def sum_to(n: int) -> (total: int) {
    0 -> total
    1 -> i
    while (i <= n) {
        total + i -> total
        i + 1 -> i
    }
}

def first_div7(n: int) -> (result: int) {
    0 -> result
    1 -> i
    while (i <= n) {
        i % 7 -> rem
        rem == 0 -> hit
        if (hit) {
            i -> result
            break
        }
        i + 1 -> i
    }
}

def sum_odds(n: int) -> (total: int) {
    0 -> total
    1 -> i
    while (i <= n) {
        i % 2 -> rem
        rem == 0 -> even
        if (even) {
            i + 1 -> i
            continue
        }
        total + i -> total
        i + 1 -> i
    }
}

def main() -> () {
    sum_to(10) -> s
    print("sum(1..10) =", s)              // 55

    first_div7(20) -> d7
    print("first div7 in [1,20] =", d7)   // 7

    sum_odds(10) -> so
    print("sum odds(1..10) =", so)        // 25
}

main() -> ()
