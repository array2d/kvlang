# save_load: 验证 save 和 load 算子完整流程
# 1. 创建 tensor  →  2. save 到磁盘 → 3. 创建新 tensor → 4. load 回内存
def save_load() -> (/data/loaded) {
    tensor.new("f32", "[10]") -> /data/src
    tensor.zeros() -> /data/src
    tensor.save(/data/src, /tmp/test_save_load)
    tensor.new("f32", "[10]") -> /data/loaded
    tensor.load(/tmp/test_save_load) -> /data/loaded
    print("loaded =", /data/loaded)
    tensor.del(/data/src)
}

str.set("kvlangrun") -> ./term

# Top-level call: save_load() -> /data/loaded
save_load() -> /data/loaded
