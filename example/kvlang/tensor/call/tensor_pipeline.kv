# tensor_pipeline: 多函数调用链，每层函数内部创建 tensor、计算、清理
# 验证深度 CALL + tensor lifecycle 正确性
# 调用链: producer → stage1 → stage2 → consumer

# ── 最内层: 创建 tensor 并做 elementwise 计算 ──
def producer() -> (/data/p) {
    tensor.new("f32", "[64]") -> /data/p
    tensor.new("f32", "[64]") -> /data/t
    tensor.zeros() -> /data/p
    tensor.add(/data/p, /data/p) -> /data/t
    tensor.mul(/data/t, /data/p) -> /data/p
    tensor.del(/data/t)
}

# ── 中间层 1: 调用 producer 并对结果做 relu ──
def stage1() -> (/data/s1) {
    producer() -> /data/s1
    tensor.new("f32", "[64]") -> /data/relu_out
    tensor.relu(/data/s1) -> /data/relu_out
    tensor.del(/data/s1)
    # 将 relu_out 重命名给调用方 (依赖 return 写入的 key)
}

# ── 中间层 2: 调用 stage1 并对结果做 exp ──
def stage2() -> (/data/s2) {
    stage1() -> /data/s2
    tensor.new("f32", "[64]") -> /data/exp_out
    exp(/data/s2) -> /data/exp_out
    tensor.del(/data/s2)
}

# ── 最外层: 调用 stage2 并打印结果，最后清理 ──
def consumer() -> () {
    stage2() -> /data/final
    print("final =", /data/final)
    tensor.del(/data/final)
}

str.set("kvlangrun") -> ./term

# Top-level call: consumer() -> ()  (full pipeline: producer→stage1→stage2→consumer)
consumer() -> ()
