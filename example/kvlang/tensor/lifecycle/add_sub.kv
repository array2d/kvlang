# add_sub: compute elementwise sum and diff — multi-output tensor with <- style
def add_sub() -> (/data/sum, /data/diff) {
    tensor.new("f32", "[64]") -> /data/a
    tensor.new("f32", "[64]") -> /data/b
    tensor.new("f32", "[64]") -> /data/sum
    tensor.new("f32", "[64]") -> /data/diff

    tensor.zeros() -> /data/a
    tensor.zeros() -> /data/b

    ./sum <- tensor.add(/data/a, /data/b)
    ./diff <- tensor.sub(/data/a, /data/b)

    tensor.del(/data/a)
    tensor.del(/data/b)
}

str.set("kvlangrun") -> ./term

# Top-level call: add_sub() -> (./out_sum, ./out_diff)
add_sub() -> (./out_sum, ./out_diff)
