# clone_and_use: 创建 tensor → clone → 分别计算 → 合并结果 → 清理
# 验证 heap-plat clonetensor + op-plat compute 协同
def clone_and_use() -> ('/data/merged') {
    tensor.new("f32", "[128]") -> '/data/original'
    tensor.zeros() -> '/data/original'
    tensor.clone('/data/original', '/data/copy')

    tensor.new("f32", "[128]") -> '/data/doubled'
    tensor.new("f32", "[128]") -> '/data/merged'

    # 对 original 做 add，对 copy 做 mul
    tensor.add('/data/original', '/data/original') -> '/data/doubled'
    tensor.mul('/data/copy', '/data/copy') -> '/data/copy'

    # 合并两个分支结果
    tensor.add('/data/doubled', '/data/copy') -> '/data/merged'

    # 只保留 merged，其他全部清理
    tensor.del('/data/original')
    tensor.del('/data/copy')
    tensor.del('/data/doubled')
}

str.set("kvlangrun") -> './term'

# Top-level call: clone_and_use() -> '/data/merged'
clone_and_use() -> '/data/merged'
