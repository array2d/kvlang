# batch_ops: 创建 5 个 tensor，多步 GPU 计算，最后全部清理
# 联调 VM → heap-plat → op-plat 完整链路
def batch_ops() -> (/data/final) {
    tensor.new("f32", "[256]") -> /data/a
    tensor.new("f32", "[256]") -> /data/b
    tensor.new("f32", "[256]") -> /data/c
    tensor.new("f32", "[256]") -> /data/d
    tensor.new("f32", "[256]") -> /data/final
    tensor.new("f32", "[256]") -> /data/temp

    # 初始化输入 tensor
    tensor.zeros() -> /data/a
    tensor.zeros() -> /data/b
    tensor.zeros() -> /data/c
    tensor.zeros() -> /data/d

    # Step 1: temp = a + b
    tensor.add(/data/a, /data/b) -> /data/temp
    # Step 2: final = temp * c  (使用 mul，GPU elementwise)
    tensor.mul(/data/temp, /data/c) -> /data/final
    # Step 3: final = final + d
    tensor.add(/data/final, /data/d) -> /data/final

    # 清理中间和输入 tensor
    tensor.del(/data/temp)
    tensor.del(/data/a)
    tensor.del(/data/b)
    tensor.del(/data/c)
    tensor.del(/data/d)
}

str.set("kvlangrun") -> ./term

# Top-level call: batch_ops() -> /data/final
batch_ops() -> /data/final
