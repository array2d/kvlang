# compute_cstyle: create, init, compute, cleanup — using <- assignment
def compute_cstyle() -> (/data/c) {
    tensor.new("f32", "[8]") -> /data/a
    tensor.new("f32", "[8]") -> /data/b
    tensor.new("f32", "[8]") -> /data/c

    tensor.zeros() -> /data/a
    tensor.zeros() -> /data/b

    ./c <- tensor.add(/data/a, /data/b)

    tensor.del(/data/a)
    tensor.del(/data/b)
}

str.set("kvlangrun") -> ./term

# Top-level call: compute_cstyle() -> ./out
compute_cstyle() -> ./out
