# native_and_gpu: VM 原生标量计算与 GPU tensor 操作交叉执行
# 验证 VM native eval → heap-plat → op-plat 混合调度正确性
def native_and_gpu(N:int) -> (/data/final) {
    # Step 1: VM 原生计算确定 tensor 大小
    N * 4 -> ./size

    # Step 2: 基于标量结果创建 tensor（此处简化为固定大小）
    tensor.new("f32", "[256]") -> /data/x
    tensor.new("f32", "[256]") -> /data/y
    tensor.new("f32", "[256]") -> /data/final

    tensor.zeros() -> /data/x
    tensor.zeros() -> /data/y

    # Step 3: GPU tensor 计算
    tensor.add(/data/x, /data/y) -> /data/final

    # Step 4: VM 原生比较 (验证标量结果还在)
    N == N -> ./valid

    tensor.del(/data/x)
    tensor.del(/data/y)
}

str.set("kvlangrun") -> ./term

# Top-level call: native_and_gpu(8) -> /data/final
native_and_gpu(8) -> /data/final
