# polynomial: 计算多项式 f(x) = a*x^2 + b*x + c  全在 GPU tensor 上
# 使用 mul + add 组合，无 pow/sqrt 等 params 依赖的算子
def polynomial() -> ('/data/result') {
    tensor.new("f32", "[128]") -> '/data/x'
    tensor.new("f32", "[128]") -> '/data/a'
    tensor.new("f32", "[128]") -> '/data/b'
    tensor.new("f32", "[128]") -> '/data/c'
    tensor.new("f32", "[128]") -> '/data/squared'
    tensor.new("f32", "[128]") -> '/data/term1'
    tensor.new("f32", "[128]") -> '/data/term2'
    tensor.new("f32", "[128]") -> '/data/result'

    tensor.zeros() -> '/data/x'
    tensor.zeros() -> '/data/a'
    tensor.zeros() -> '/data/b'
    tensor.zeros() -> '/data/c'

    # x^2
    tensor.mul('/data/x', '/data/x') -> '/data/squared'
    # a * x^2
    tensor.mul('/data/a', '/data/squared') -> '/data/term1'
    # b * x
    tensor.mul('/data/b', '/data/x') -> '/data/term2'
    # term1 + term2
    tensor.add('/data/term1', '/data/term2') -> '/data/result'
    # + c
    tensor.add('/data/result', '/data/c') -> '/data/result'

    tensor.del('/data/squared')
    tensor.del('/data/term1')
    tensor.del('/data/term2')
    tensor.del('/data/x')
    tensor.del('/data/a')
    tensor.del('/data/b')
    tensor.del('/data/c')
}

str.set("kvlangrun") -> './term'

# Top-level call: polynomial() -> '/data/result'
polynomial() -> '/data/result'
