# mlp_small: 模拟单隐藏层 MLP forward pass（无控制流，逐 op 展开）
# 联调 VM + heap-plat (newtensor/deltensor) + op-plat (add/mul/relu)
# 数学: hidden = relu(X * W + B), output = hidden * W2 + B2
def mlp_small() -> ('/data/output') {
    # ── 分配所有权重/偏置/中间结果 ──
    tensor.new("f32", "[64]") -> '/data/X'
    tensor.new("f32", "[64]") -> '/data/W'
    tensor.new("f32", "[64]") -> '/data/B'
    tensor.new("f32", "[64]") -> '/data/W2'
    tensor.new("f32", "[64]") -> '/data/B2'
    tensor.new("f32", "[64]") -> '/data/t1'
    tensor.new("f32", "[64]") -> '/data/t2'
    tensor.new("f32", "[64]") -> '/data/hidden'
    tensor.new("f32", "[64]") -> '/data/t3'
    tensor.new("f32", "[64]") -> '/data/output'

    # 初始化权重和输入
    tensor.zeros() -> '/data/X'
    tensor.zeros() -> '/data/W'
    tensor.zeros() -> '/data/B'
    tensor.zeros() -> '/data/W2'
    tensor.zeros() -> '/data/B2'

    # ── Layer 1: hidden = relu(X * W + B) ──
    tensor.mul('/data/X', '/data/W') -> '/data/t1'
    tensor.add('/data/t1', '/data/B') -> '/data/t2'
    tensor.relu('/data/t2') -> '/data/hidden'

    # ── Layer 2: output = hidden * W2 + B2 ──
    tensor.mul('/data/hidden', '/data/W2') -> '/data/t3'
    tensor.add('/data/t3', '/data/B2') -> '/data/output'

    # ── 清理中间结果，保留 output ──
    tensor.del('/data/t1')
    tensor.del('/data/t2')
    tensor.del('/data/t3')
    tensor.del('/data/hidden')
    tensor.del('/data/X')
    tensor.del('/data/W')
    tensor.del('/data/B')
    tensor.del('/data/W2')
    tensor.del('/data/B2')
}

str.set("kvlangrun") -> './term'

# Top-level call: mlp_small() -> '/data/output'
mlp_small() -> '/data/output'
