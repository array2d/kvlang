# dist2: 逐元素平方差 (a - b)^2，用于距离计算的元素部分
# 全程 GPU tensor: sub → mul
def dist2() -> (/data/dist2) {
    tensor.new("f32", "[256]") -> /data/a
    tensor.new("f32", "[256]") -> /data/b
    tensor.new("f32", "[256]") -> /data/diff
    tensor.new("f32", "[256]") -> /data/dist2

    tensor.zeros() -> /data/a
    tensor.zeros() -> /data/b

    # diff = a - b
    ./diff <- tensor.sub(/data/a, /data/b)
    # dist2 = diff * diff
    ./dist2 <- tensor.mul(/data/diff, /data/diff)

    tensor.del(/data/a)
    tensor.del(/data/b)
    tensor.del(/data/diff)
}

str.set("kvlangrun") -> ./term

# Top-level call: dist2() -> /data/dist2
dist2() -> /data/dist2
