# hadamard3: 三元 Hadamard 积 a * b * c
# mul 是 binary GPU op，分两步完成
def hadamard3() -> ('/data/result') {
    tensor.new("f32", "[128]") -> '/data/a'
    tensor.new("f32", "[128]") -> '/data/b'
    tensor.new("f32", "[128]") -> '/data/c'
    tensor.new("f32", "[128]") -> '/data/temp'
    tensor.new("f32", "[128]") -> '/data/result'

    tensor.zeros() -> '/data/a'
    tensor.zeros() -> '/data/b'
    tensor.zeros() -> '/data/c'

    # temp = a * b
    tensor.mul('/data/a', '/data/b') -> '/data/temp'
    # result = temp * c
    tensor.mul('/data/temp', '/data/c') -> '/data/result'

    tensor.del('/data/a')
    tensor.del('/data/b')
    tensor.del('/data/c')
    tensor.del('/data/temp')
}

str.set("kvlangrun") -> './term'

# Top-level call: hadamard3() -> '/data/result'
hadamard3() -> '/data/result'
