# block_loop: 基本块实现循环 (br + goto)
# 使用基本块模拟 while/for 循环

def 块循环求和(N:int) -> (total:int) {
    entry: {
        0 -> ./total
        1 -> ./i
        goto(cond)
    }

    cond: {
        ./i <= N -> ./more
        br(./more, body, exit)
    }

    body: {
        ./total + ./i -> ./total
        goto(step)
    }

    step: {
        ./i + 1 -> ./i
        goto(cond)
    }

    exit: {
        return
    }
}

def 块循环阶乘(N:int) -> (result:int) {
    entry: {
        1 -> ./result
        1 -> ./i
        goto(cond)
    }

    cond: {
        ./i <= N -> ./more
        br(./more, body, exit)
    }

    body: {
        ./result * ./i -> ./result
        goto(step)
    }

    step: {
        ./i + 1 -> ./i
        goto(cond)
    }

    exit: {
        return
    }
}
