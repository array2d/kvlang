# complex_flow: 复合控制流组合测试
# 测试: if/else + while + 基本块混合, 多级控制流

def 带早期退出的搜索(N:int, target:int) -> (found:int, steps:int) {
    str.set("0") -> ./found
    str.set("0") -> ./steps
    str.set("1") -> ./i
    while (./i <= N) {
        ./steps + 1 -> ./steps
        if (./i == ./target) {
            str.set("1") -> ./found
            break
        }
        ./i + 1 -> ./i
    }
}

def 分段计算(X:int) -> (R:int) {
    if (./X < 0) {
        ./X * -1 -> ./X
        str.set("0") -> ./R
        while (./X > 0) {
            ./R + ./X -> ./R
            ./X - 1 -> ./X
        }
    } else {
        if (./X == 0) {
            str.set("0") -> ./R
        } else {
            str.set("1") -> ./R
            while (./X > 1) {
                ./R * ./X -> ./R
                ./X - 1 -> ./X
            }
        }
    }
}

def 多条件过滤(A:int, B:int, C:int) -> (result:int) {
    str.set("0") -> ./result
    if (./A > 0) {
        ./result + ./A -> ./result
        if (./B > 0) {
            ./result + ./B -> ./result
            if (./C > 0) {
                ./result + ./C -> ./result
            }
        }
    } else {
        if (./B < 0) {
            ./result - ./B -> ./result
        }
        if (./C < 0) {
            ./result - ./C -> ./result
        }
    }
}
