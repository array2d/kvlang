# while_loop: 结构化 while 循环
# 测试: 累加求和, 累乘阶乘, 指数递减, 条件累加

def 累加求和(N:int) -> (total:int) {
    0 -> ./total
    1 -> ./i
    while (./i <= N) {
        ./total + ./i -> ./total
        ./i + 1 -> ./i
    }
}

def 累乘阶乘(N:int) -> (result:int) {
    1 -> ./result
    1 -> ./i
    while (./i <= N) {
        ./result * ./i -> ./result
        ./i + 1 -> ./i
    }
}

def 指数递减(N:int) -> (steps:int) {
    0 -> ./steps
    while (./N > 1) {
        ./steps + 1 -> ./steps
        ./N / 2 -> ./N
    }
}

def 条件累加(limit:int, step:int) -> (total:int) {
    0 -> ./total
    0 -> ./n
    while (./total < ./limit) {
        ./n + ./step -> ./n
        ./total + ./n -> ./total
    }
}
