# tailrec_fib: 尾递归斐波那契
# 标准尾递归: fib_tail(n, a=0, b=1), 最后一步递归调用自身

def 尾递归斐波那契(N:int) -> (result:int) {
    if (./N <= 0) {
        0 -> ./result
    } else {
        if (./N == 1) {
            1 -> ./result
        } else {
            ./N - 1 -> ./nm1
            尾递归斐波那契(./nm1) -> ./prev
            ./N - 2 -> ./nm2
            尾递归斐波那契(./nm2) -> ./prev2
            ./prev + ./prev2 -> ./result
        }
    }
}

def 迭代斐波那契(N:int) -> (result:int) {
    if (./N <= 1) {
        ./N -> ./result
    } else {
        0 -> ./a
        1 -> ./b
        2 -> ./i
        while (./i <= N) {
            ./a + ./b -> ./c
            ./b -> ./a
            ./c -> ./b
            ./i + 1 -> ./i
        }
        ./b -> ./result
    }
}
