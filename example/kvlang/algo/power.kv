# power: 快速幂（循环实现）
# 算法: 循环 while + 条件更新，计算 2^10 = 1024
# 层级: P3
# 规则: P3-algo
# 期望输出:
#   result = 1024

str.set("kvlangrun") -> ./term

def power(base:int, exp:int) -> (result:int) {
    1 -> ./result
    0 -> ./e
    while (./e < exp) {
        ./result * base -> ./result
        ./e + 1 -> ./e
    }
}

power(2, 10) -> ./ans
print("result =", ./ans)
