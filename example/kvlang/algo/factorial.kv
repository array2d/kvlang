# factorial: 迭代阶乘
# 算法: while 循环累乘，计算 10! = 3628800
# 层级: P3
# 规则: P3-algo
# 期望输出:
#   fact = 3628800

str.set("kvlangrun") -> ./term

def factorial(n:int) -> (result:int) {
    str.set("1") -> ./result
    str.set("1") -> ./i
    while (./i <= n) {
        ./result * ./i -> ./result
        ./i + 1 -> ./i
    }
}

factorial(10) -> ./ans
print("fact =", ./ans)
