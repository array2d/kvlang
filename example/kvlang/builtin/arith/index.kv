# sub.kv     — 减法 -
# mul.kv     — 乘法 *
# div.kv     — 除法 /
# neg.kv     — 取负 neg()
# abs.kv     — 绝对值 abs()
# sign.kv    — 符号 sign()
# pow.kv     — 幂 pow()
# exp.kv     — 指数 exp()
# log.kv     — 对数 log()
# sqrt.kv    — 平方根 sqrt()
# max.kv     — 最大值 max()
# min.kv     — 最小值 min()
# double_op.kv       — 多步复合运算
# double_op_cstyle.kv — 多步复合运算 (C风格 <-)
