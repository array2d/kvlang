# nested_call: 验证嵌套调用时子帧不污染父帧局部变量（CR-5）
# outer 调用 inner 前后，outer 局部变量 X=100 不变
# 层级: P1
# 规则: CR-5
# 期望输出:
#   before = 100
#   inner = 42
#   after = 100

str.set("kvlangrun") -> ./term

def inner_fn(N:int) -> (R:int) {
    N * 2 -> ./R
}

def outer_fn(X:int) -> (R:int) {
    print("before =", X)
    inner_fn(21) -> ./ir
    print("inner =", ./ir)
    print("after =", X)
    X + 0 -> ./R
}

outer_fn(100) -> ./out
