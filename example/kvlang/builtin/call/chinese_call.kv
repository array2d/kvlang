# chinese_call — 复杂中文函数调用测试
# 验证: 中文函数定义 / 中文函数间调用 / 中文参数名 / 链式组合

# 倍增: 将输入放大两倍
def 倍增(原始值:int) -> (结果值:int) {
    原始值 * 2 -> './结果值'
}

# 平方: 计算输入的平方
def 平方(底数:int) -> (幂:int) {
    底数 * 底数 -> './幂'
}

# 多项式: f(x) = a*x² + b*x + c
#         = a*平方(x) + b*x + c
def 多项式(X:int, 参数A:int, 参数B:int, 参数C:int) -> (最终结果:int) {
    平方(X) -> './二次项'
    参数A * './二次项' -> './首项'
    参数B * X -> './一次项'
    './首项' + './一次项' -> './前两项和'
    './前两项和' + 参数C -> './最终结果'
}

# 组合计算: 先倍增再计算多项式
def 复杂流程(输入值:int) -> (输出值:int) {
    倍增(输入值) -> './放大后'
    多项式('./放大后', 2, 3, 1) -> './输出值'
}

str.set("kvlangrun") -> './term'

# 顶层调用链
倍增(5) -> './倍增值'
平方(4) -> './平方值'
多项式(3, 2, 3, 1) -> './多项结果'
复杂流程(3) -> './最终输出'
