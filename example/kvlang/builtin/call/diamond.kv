# diamond: 验证菱形调用（A→B→D, A→C→D）共享被调函数不冲突（CR-6）
# A 调 double(5)=10 和 triple(5)=15，再求和 = 25
# 层级: P1
# 规则: CR-6
# 期望输出:
#   R = 25

str.set("kvlangrun") -> ./term

def dbl(X:int) -> (Y:int) {
    ./Y <- X * 2
}

def tpl(X:int) -> (Y:int) {
    ./Y <- X * 3
}

def diamond(A:int) -> (R:int) {
    dbl(A) -> ./d
    tpl(A) -> ./t
    ./d + ./t -> ./R
}

diamond(5) -> ./out
print("R =", ./out)
