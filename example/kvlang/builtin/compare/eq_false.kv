# eq_false: 验证 == 在不相等输入下产生 false
# 层级: P1
# 规则: compare/==
# 等价类: H-不等→false (5==6)  E-零与一→false (0==1)
# 期望输出:
#   H = false
#   E = false

str.set("kvlangrun") -> ./term

def eq_fn(A:int, B:int) -> (C:bool) {
    ./C <- A == B
}

eq_fn(5, 6) -> ./h
print("H =", ./h)

eq_fn(0, 1) -> ./e
print("E =", ./e)
