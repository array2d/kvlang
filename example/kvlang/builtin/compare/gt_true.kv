# gt_true: 验证 > 在严格大于输入下产生 true
# 层级: P1
# 规则: compare/>
# 等价类: H-严格大于→true (7>3)  E-边界大于→true (7>6)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def gt_fn(A:int, B:int) -> (C:bool) {
    ./C <- A > B
}

gt_fn(7, 3) -> ./h
print("H =", ./h)

gt_fn(7, 6) -> ./e
print("E =", ./e)
