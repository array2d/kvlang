# eq_true: 验证 == 在相等输入下产生 true
# 层级: P1
# 规则: compare/==
# 等价类: H-相等→true (5==5)  E-零值相等→true (0==0)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def eq_h(A:int, B:int) -> (C:bool) {
    ./C <- A == B
}

def eq_e(A:int, B:int) -> (C:bool) {
    ./C <- A == B
}

eq_h(5, 5) -> ./h
print("H =", ./h)

eq_e(0, 0) -> ./e
print("E =", ./e)
