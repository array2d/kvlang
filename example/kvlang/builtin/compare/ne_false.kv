# ne_false: 验证 != 在相等输入下产生 false
# 层级: P1
# 规则: compare/!=
# 等价类: H-相等→false (5!=5)  E-零值相等→false (0!=0)
# 期望输出:
#   H = false
#   E = false

str.set("kvlangrun") -> ./term

def ne_fn(A:int, B:int) -> (C:bool) {
    ./C <- A != B
}

ne_fn(5, 5) -> ./h
print("H =", ./h)

ne_fn(0, 0) -> ./e
print("E =", ./e)
