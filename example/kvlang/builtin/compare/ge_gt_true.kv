# ge_gt_true: 验证 >= 在大于输入下产生 true
# 层级: P1
# 规则: compare/>=
# 等价类: H-大于→true (7>=3)  E-边界大于→true (7>=6)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def ge_fn(A:int, B:int) -> (C:bool) {
    ./C <- A >= B
}

ge_fn(7, 3) -> ./h
print("H =", ./h)

ge_fn(7, 6) -> ./e
print("E =", ./e)
