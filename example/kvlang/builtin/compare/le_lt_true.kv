# le_lt_true: 验证 <= 在小于输入下产生 true
# 层级: P1
# 规则: compare/<=
# 等价类: H-小于→true (3<=7)  E-边界小于→true (6<=7)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def le_fn(A:int, B:int) -> (C:bool) {
    ./C <- A <= B
}

le_fn(3, 7) -> ./h
print("H =", ./h)

le_fn(6, 7) -> ./e
print("E =", ./e)
