# lt_true: 验证 < 在严格小于输入下产生 true
# 层级: P1
# 规则: compare/<
# 等价类: H-严格小于→true (3<7)  E-边界小于→true (6<7)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def lt_fn(A:int, B:int) -> (C:bool) {
    ./C <- A < B
}

lt_fn(3, 7) -> ./h
print("H =", ./h)

lt_fn(6, 7) -> ./e
print("E =", ./e)
