# ne_true: 验证 != 在不相等输入下产生 true
# 层级: P1
# 规则: compare/!=
# 等价类: H-不等→true (5!=6)  E-零与一→true (0!=1)
# 期望输出:
#   H = true
#   E = true

str.set("kvlangrun") -> ./term

def ne_fn(A:int, B:int) -> (C:bool) {
    ./C <- A != B
}

ne_fn(5, 6) -> ./h
print("H =", ./h)

ne_fn(0, 1) -> ./e
print("E =", ./e)
