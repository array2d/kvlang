# ge_lt_false: 验证 >= 在小于输入下产生 false
# 层级: P1
# 规则: compare/>=
# 等价类: H-小于→false (3>=7)  E-边界小于→false (6>=7)
# 期望输出:
#   H = false
#   E = false

str.set("kvlangrun") -> ./term

def ge_fn(A:int, B:int) -> (C:bool) {
    ./C <- A >= B
}

ge_fn(3, 7) -> ./h
print("H =", ./h)

ge_fn(6, 7) -> ./e
print("E =", ./e)
